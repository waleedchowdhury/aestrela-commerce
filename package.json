{
  "name": "aestrela-commerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate --schema prisma/schema.sqlserver.prisma && next dev",
    "dev:postgres": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "build:pages": "node scripts/build-pages.mjs",
    "start": "node scripts/start.mjs",
    "lint": "eslint . --max-warnings=0",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:generate:sqlserver": "prisma generate --schema prisma/schema.sqlserver.prisma",
    "prisma:push:sqlserver": "prisma db push --schema prisma/schema.sqlserver.prisma",
    "prisma:seed:sqlserver": "tsx prisma/seed.ts",
    "dev:sqlserver": "prisma generate --schema prisma/schema.sqlserver.prisma && next dev"
  },
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@prisma/client": "^5.22.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
