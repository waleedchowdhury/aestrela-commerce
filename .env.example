# Vercel Prisma Postgres / Postgres production example:
# DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# Local development with the Vercel CLI:
# Run `vercel env pull .env` after connecting a Postgres database in Vercel.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

ADMIN_PASSWORD="change-this-before-launch"
ADMIN_COOKIE_SECRET="replace-with-a-long-random-string"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENVIRONMENT="sandbox"

# Render persistent disk path for admin uploads.
# Locally, leave this unset so uploads write to public/uploads.
UPLOAD_DIR="/var/data/uploads"
